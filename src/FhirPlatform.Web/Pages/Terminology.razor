@page "/terminology"
@using System.Net.Http.Json
@using FhirPlatform.Application.Contracts
@inject IHttpClientFactory HttpClientFactory

<h2>Terminology</h2>
<p class="text-muted">Search CodeSystems, ValueSets and ConceptMaps, and call configured FHIR terminology operations through the custom API.</p>
<label class="form-label" for="filter">Filter</label><input id="filter" class="form-control" @bind="_filter" />
<div class="btn-group my-3"><button class="btn btn-primary" @onclick="() => SearchAsync(\"code-systems\")">CodeSystems</button><button class="btn btn-primary" @onclick="() => SearchAsync(\"value-sets\")">ValueSets</button><button class="btn btn-primary" @onclick="() => SearchAsync(\"concept-maps\")">ConceptMaps</button></div>
<table class="table"><thead><tr><th>Type</th><th>Name</th><th>URL</th><th>Version</th><th>Status</th></tr></thead><tbody>@foreach (var item in _results) { <tr><td>@item.ResourceType</td><td>@(item.Title ?? item.Name)</td><td><code>@item.Url</code></td><td>@item.Version</td><td>@item.Status</td></tr> }</tbody></table>

@code {
    private string? _filter;
    private IReadOnlyList<TerminologyResourceSummaryDto> _results = Array.Empty<TerminologyResourceSummaryDto>();
    private async Task SearchAsync(string endpoint)
    {
        var client = HttpClientFactory.CreateClient("Api");
        _results = await client.GetFromJsonAsync<IReadOnlyList<TerminologyResourceSummaryDto>>($"api/terminology/{endpoint}?filter={Uri.EscapeDataString(_filter ?? string.Empty)}") ?? Array.Empty<TerminologyResourceSummaryDto>();
    }
}
