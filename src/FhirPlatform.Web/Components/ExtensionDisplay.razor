@using Hl7.Fhir.Model
@if (Extensions.Count == 0)
{
    <span class="text-muted">No extensions</span>
}
else
{
    <ul class="list-unstyled mb-0">
        @foreach (var extension in Extensions)
        {
            <li><code>@extension.Url</code> <span>@ValueText(extension)</span>
                @if (extension.Extension.Count > 0)
                {
                    <ExtensionDisplay Extensions="extension.Extension" />
                }
            </li>
        }
    </ul>
}
@code {
    [Parameter] public IReadOnlyCollection<Extension> Extensions { get; set; } = Array.Empty<Extension>();
    private static string ValueText(Extension extension) => extension.Value switch
    {
        FhirString value => value.Value,
        FhirBoolean value => value.Value?.ToString() ?? string.Empty,
        FhirDecimal value => value.Value?.ToString() ?? string.Empty,
        FhirDateTime value => value.Value,
        CodeableConcept value => value.Text ?? value.Coding.FirstOrDefault()?.Display ?? string.Empty,
        Coding value => value.Display ?? value.Code ?? string.Empty,
        Quantity value => $"{value.Value} {value.Unit ?? value.Code}",
        _ => extension.Value?.ToString() ?? string.Empty
    };
}
