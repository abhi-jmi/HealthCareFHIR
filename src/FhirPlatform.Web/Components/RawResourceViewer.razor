<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@Title</span>
        <span class="badge text-bg-secondary">@Format</span>
    </div>
    <pre class="card-body overflow-auto" style="max-height: 32rem"><code>@Content</code></pre>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Raw resource";
    [Parameter] public string Format { get; set; } = "FHIR JSON";
    [Parameter] public string? Content { get; set; }
}
